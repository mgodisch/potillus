    "Add a drink to start logging.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a drink to start logging."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge ein Getränk hinzu, um zu beginnen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilføj en drik for at begynde at registrere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg een drankje toe om te beginnen met registreren."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Legg til en drink for å begynne å registrere."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägg till en dryck för att börja registrera."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade una bebida para empezar a registrar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez une boisson pour commencer l’enregistrement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi una bevanda per iniziare a registrare."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione uma bebida para começar a registar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione uma bebida para começar a registrar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Adaugă o băutură pentru a începe înregistrarea."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přidejte nápoj a začněte zaznamenávat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj napój, aby rozpocząć rejestrowanie."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте напиток, чтобы начать запись."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додайте напій, щоб почати запис."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσθέστε ένα ποτό για να ξεκινήσετε την καταγραφή."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "飲み物を追加して記録を始めましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음료를 추가하여 기록을 시작하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加一杯饮品以开始记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增一杯飲品以開始記錄。"
          }
        }
      }
    },
