    "Add a drink to start logging.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a drink to start logging."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge ein Getränk hinzu, um zu beginnen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilføj en drik for at begynde at registrere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg een drankje toe om te beginnen met registreren."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Legg til en drink for å begynne å registrere."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägg till en dryck för att börja registrera."
          }
        },
