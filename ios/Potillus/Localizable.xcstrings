    "Replacing deletes your log and the drinks you created. Presets are kept.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Replacing deletes your log and the drinks you created. Presets are kept."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beim Ersetzen werden dein Logbuch und die von dir erstellten Getränke gelöscht. Vorlagen bleiben erhalten."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstatning sletter din log og de drikke, du har oprettet. Forudindstillinger bevares."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vervangen verwijdert je logboek en de door jou gemaakte drankjes. Voorinstellingen blijven behouden."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstatning sletter loggen din og drinkene du har opprettet. Forhåndsinnstillinger beholdes."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ersättning raderar din logg och de drycker du har skapat. Förinställningar behålls."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reemplazar elimina tu registro y las bebidas que creaste. Los preajustes se conservan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le remplacement supprime votre journal et les boissons que vous avez créées. Les préréglages sont conservés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La sostituzione elimina il tuo registro e le bevande che hai creato. Le preimpostazioni vengono mantenute."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Substituir elimina o seu registo e as bebidas que criou. As predefinições são mantidas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Substituir exclui seu registro e as bebidas que você criou. As predefinições são mantidas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înlocuirea șterge jurnalul tău și băuturile create de tine. Presetările sunt păstrate."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nahrazení smaže váš deník a nápoje, které jste vytvořili. Předvolby zůstanou zachovány."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zastąpienie usuwa dziennik i utworzone przez Ciebie napoje. Ustawienia wstępne są zachowywane."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Замена удаляет ваш журнал и созданные вами напитки. Шаблоны сохраняются."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Заміна видаляє ваш журнал і створені вами напої. Шаблони зберігаються."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η αντικατάσταση διαγράφει το ημερολόγιό σας και τα ποτά που δημιουργήσατε. Οι προεπιλογές διατηρούνται."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "置き換えると記録と作成した飲み物が削除されます。プリセットは保持されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "교체하면 기록과 직접 만든 음료가 삭제됩니다. 프리셋은 유지됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "替换会删除你的记录和你创建的饮品。预设会保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "取代會刪除你的記錄和你建立的飲品。預設會保留。"
          }
        }
      }
    },
