    "Days before this date are ignored in statistics. Entries are not deleted.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Days before this date are ignored in statistics. Entries are not deleted."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tage vor diesem Datum werden in der Statistik ignoriert. Einträge werden nicht gelöscht."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dage før denne dato ignoreres i statistikken. Registreringer slettes ikke."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dagen vóór deze datum worden in de statistieken genegeerd. Registraties worden niet verwijderd."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dager før denne datoen ignoreres i statistikken. Registreringer slettes ikke."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dagar före detta datum ignoreras i statistiken. Poster raderas inte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los días anteriores a esta fecha se ignoran en las estadísticas. Los registros no se eliminan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les jours avant cette date sont ignorés dans les statistiques. Les entrées ne sont pas supprimées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I giorni precedenti a questa data sono ignorati nelle statistiche. Le voci non vengono eliminate."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os dias anteriores a esta data são ignorados nas estatísticas. Os registos não são eliminados."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os dias anteriores a esta data são ignorados nas estatísticas. Os registros não são excluídos."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Zilele anterioare acestei date sunt ignorate în statistici. Înregistrările nu sunt șterse."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dny před tímto datem jsou ve statistikách ignorovány. Záznamy nejsou smazány."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dni przed tą datą są ignorowane w statystykach. Wpisy nie są usuwane."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дни до этой даты игнорируются в статистике. Записи не удаляются."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Дні до цієї дати ігноруються в статистиці. Записи не видаляються."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι ημέρες πριν από αυτήν την ημερομηνία αγνοούνται στα στατιστικά. Οι καταχωρίσεις δεν διαγράφονται."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この日付より前の日は統計で無視されます。記録は削除されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 날짜 이전의 날은 통계에서 무시됩니다. 기록은 삭제되지 않습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此日期之前的日子在统计中被忽略。记录不会被删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此日期之前的日子在統計中會被忽略。記錄不會被刪除。"
          }
        }
      }
    },
