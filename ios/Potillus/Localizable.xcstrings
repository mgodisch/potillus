    "A drink logged before this time counts towards the previous day.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A drink logged before this time counts towards the previous day."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Getränk vor dieser Uhrzeit zählt zum Vortag."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En drik registreret før dette tidspunkt tæller til den foregående dag."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een drankje dat vóór dit tijdstip wordt geregistreerd, telt voor de vorige dag."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En drink registrert før dette tidspunktet teller til dagen før."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En dryck som registreras före denna tid räknas till föregående dag."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una bebida registrada antes de esta hora cuenta para el día anterior."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une boisson enregistrée avant cette heure compte pour la veille."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una bevanda registrata prima di quest’ora conta per il giorno precedente."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma bebida registada antes desta hora conta para o dia anterior."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma bebida registrada antes deste horário conta para o dia anterior."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "O băutură înregistrată înainte de această oră se contorizează pentru ziua precedentă."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nápoj zaznamenaný před tímto časem se počítá do předchozího dne."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Napój zarejestrowany przed tą godziną liczy się do poprzedniego dnia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Напиток, записанный до этого времени, засчитывается за предыдущий день."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Напій, записаний до цього часу, зараховується до попереднього дня."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ένα ποτό που καταγράφεται πριν από αυτήν την ώρα προσμετράται στην προηγούμενη ημέρα."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この時刻より前に記録された飲み物は前日に数えられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 시간 이전에 기록된 음료는 전날로 계산됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在此时间之前记录的饮品计入前一天。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在此時間之前記錄的飲品計入前一天。"
          }
        }
      }
    },
