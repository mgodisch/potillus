# =============================================================================
# .gitignore -- Libellus Potionis
# =============================================================================
# Entries are grouped by theme. The `tgz` target derives the release-tarball
# exclude set from these patterns (stripping comments and blank lines), so every
# entry stays a plain path pattern -- no negations (!), which tgz cannot express,
# and no inline comments (git only honours a `#` at the start of a line).
# =============================================================================

# ── Editor & OS scratch files ────────────────────────────────────────────────
.*.swp
*.log
*.orig
*.pyc
__pycache__/
.DS_Store

# ── Build outputs & tool caches (never source) ───────────────────────────────
# Report PDFs rendered at the repo root, and a local scratch directory.
/*.pdf
/short
# Android Gradle/Kotlin caches, build trees and the rendered-guides intermediate.
/android/.gradle
/android/.kotlin
/android/app/build
/android/build
/android/guides.d
# fastlane bundler/vendor directories.
/fastlane/.bundle
/fastlane/.vendor
# fastlane writes a JUnit-style run report after every invocation: a build
# artifact (fresh timestamps each run), not a source file.
/fastlane/report.xml
/fastlane/metadata/android/*/images/.goutputstream-
# Generated by `make screenshots-ios`.
/fastlane/screenshots/ios/screenshots.html

# ── Generated in-tree, git-ignored so a committed copy cannot drift ──────────
# Each is produced from a single source of truth by a make target; committing a
# copy would let it drift from that source.
# Android license copies and the rendered user guide, under res/raw*/.
/android/app/src/main/res/raw/license_gpl3.md
/android/app/src/main/res/raw/license_apache2.md
/android/app/src/main/res/raw/license_gpl2.md
/android/app/src/main/res/raw*/usersguide.md
# iOS: version xcconfig (`make -C ios version`), the xcodeproj (`make -C ios
# project`, xcodegen), the license copy and user guides (`make -C ios project` /
# `make -C ios guides`), and fastlane's SnapshotHelper (`make screenshots-ios`).
/ios/Version.xcconfig
/ios/Potillus.xcodeproj
/ios/Potillus/Resources/license_gpl3.md
/ios/Potillus/Resources/usersguide_*.md
/ios/PotillusUITests/SnapshotHelper.swift

# ── Staged release artifacts ─────────────────────────────────────────────────
# `make release-android` copies the signed AAB/APK and the SBOM here under their
# canonical <applicationId>_<versionCode>.<ext> names; push-playstore /
# push-codeberg upload from here. Build outputs, never source.
/releases

# ── Secrets -- NEVER commit ──────────────────────────────────────────────────
# Signing material and store-upload credentials. The committed templates are
# android/keystore.properties.example, ios/signing.properties.example and the
# SUPPLY_JSON_KEY note in fastlane/Appfile.
/android/keystore.properties
/ios/signing.properties
/fastlane/play-store-credentials.json
/fastlane/codeberg-credentials.txt
# App Store Connect API key (.p8) for the iOS deliver lanes: it downloads once and
# cannot be re-downloaded. Read via the APP_STORE_CONNECT_API_KEY_* env vars (see
# fastlane/Fastfile, iOS block).
/fastlane/AuthKey_*.p8
# App Store reviewer contact -- a real person, reachable by phone, which a public
# repository should not answer. deliver reads these as <key>.txt from
# fastlane/metadata/ios/review_information/ and sends them to App Store Connect;
# set up once per machine from the .txt.example files beside them. The directory's
# notes.txt/demo_user.txt/demo_password.txt stay committed (they describe the app,
# which has no login -- not a person). tools/check-ios-metadata.py validates these
# when present, and push-appstore refuses to upload without them.
/fastlane/metadata/ios/review_information/first_name.txt
/fastlane/metadata/ios/review_information/last_name.txt
/fastlane/metadata/ios/review_information/email_address.txt
/fastlane/metadata/ios/review_information/phone_number.txt
