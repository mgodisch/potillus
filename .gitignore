.*.swp
*.log
*.orig
*.pyc
__pycache__/
.DS_Store

/*.pdf
/android/.gradle
/android/.kotlin
/fastlane/.bundle
/fastlane/.vendor
# fastlane writes a JUnit-style run report after every invocation; it is a
# build artifact (fresh timestamps each run), not a source file.
/fastlane/report.xml
/fastlane/metadata/android/*/images/.goutputstream-

/android/app/build
/android/app/src/main/res/raw*/copyright.md
/android/app/src/main/res/raw*/usersguide.md
/android/guides.d
/android/build
/short
# Staged release artifacts: `make release` copies the signed AAB/APK and the SBOM
# here under their canonical <applicationId>_<versionCode>.<ext> names, and
# push-playstore / push-codeberg upload from here. Build outputs, never source.
/releases

# Release signing material and store upload credentials (Play + Codeberg) —
# SECRET, never commit. The committed templates are
# android/keystore.properties.example and the SUPPLY_JSON_KEY note in
# fastlane/Appfile.
/android/keystore.properties
/fastlane/play-store-credentials.json
/fastlane/codeberg-credentials.txt
# App Store Connect API key (.p8) for the iOS deliver lanes — SECRET, downloads
# once and cannot be re-downloaded. Referenced via APP_STORE_CONNECT_API_KEY_*
# env vars (see fastlane/Fastfile, iOS block).
/fastlane/AuthKey_*.p8
# ignore iOS screenshots artifacts
/fastlane/screenshots/ios/screenshots.html

# Generated by 'make ios-project' from COPYING.md and the licence files, like
# Version.xcconfig — a copy in the tree would drift from the source.
/ios/Potillus/Resources/copyright.md

# fastlane's own SnapshotHelper.swift, materialized by 'make screenshots-ios' from
# the installed fastlane (version-matched, never vendored) and picked up by
# xcodegen's PotillusUITests source glob. A committed copy would drift.
/ios/PotillusUITests/SnapshotHelper.swift
