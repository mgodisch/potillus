# EditorConfig — https://editorconfig.org
#
# Kotlin style settings consumed by ktlint (silver criterion
# `coding_standards_enforced`). This block is scoped to Kotlin source and script
# files so it does not impose settings on other file types; the per-file vim
# modelines used elsewhere in the tree continue to govern those.
#
# `ktlint_code_style = intellij_idea` selects the official Kotlin coding
# conventions (as enforced by IntelliJ IDEA), which is the style declared in
# CONTRIBUTING.md §4.

root = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
ktlint_code_style = intellij_idea

# The existing sources use deliberate, occasionally long, hand-aligned lines.
# The max-line-length rule cannot be auto-fixed by `ktlintFormat`, so it is left
# off for now to avoid a wall of non-fixable failures on adoption; it can be
# enabled later once the affected lines are reflowed.
max_line_length = off

# ── Deliberately disabled standard rules ─────────────────────────────────────
# These rules conflict with intentional, project-wide idioms rather than catching
# real defects, so they are turned off instead of churning the whole tree to
# satisfy them. (ktlintFormat cannot auto-correct any of them.)

# Jetpack Compose @Composable functions are PascalCase by convention (that IS the
# Compose naming rule). Exempt them from the lowercase function-naming rule rather
# than renaming — renaming would break the Compose idiom. Non-Composable functions
# are still checked.
ktlint_function_naming_ignore_when_annotated_with = Composable

# Compose UI code idiomatically imports whole packages (e.g.
# androidx.compose.material3.*, foundation.layout.*). Expanding ~60 wildcards to
# explicit imports adds churn without benefit, so the rule is disabled project-wide.
ktlint_standard_no-wildcard-imports = disabled

# The ViewModels expose their state through a combined public `uiState` flow, so
# the private `_x = MutableStateFlow(...)` fields legitimately have no matching
# public `x`. That is a deliberate backing-state convention, not a naming defect;
# the backing-property-naming rule (which assumes _x ⇒ public x) does not fit it.
ktlint_standard_backing-property-naming = disabled

# ── File 'ViewModels.kt' should not be empty ─────────────────────────────────
# ui/screen/ViewModels.kt is an intentional package-overview documentation file
# (GPL header + package KDoc, no declarations). Keep the documentation and exempt
# only this one file from the no-empty-file rule instead of deleting it.
[**/ui/screen/ViewModels.kt]
ktlint_standard_no-empty-file = disabled
