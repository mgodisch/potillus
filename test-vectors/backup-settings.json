{
  "_comment": [
    "Shared golden vectors for the backup 'settings' block sanitiser, harvested from",
    "Android's BackupManager.parseSettings. Loaded by BOTH suites.",
    "A backup file is user-editable and may come from a newer app, so every value is",
    "range-checked before it can influence the alcohol maths. weightKg keeps 0.0 as",
    "the 'not set' sentinel: it is NOT clamped up to the 1 kg floor, or an unset",
    "weight would silently become a 1 kg body.",
    "statsFromDate is kept only when it round-trips through the canonical yyyy-MM-dd",
    "formatter; anything else becomes blank rather than mis-bucketing statistics.",
    "language is matched case-insensitively against the locale catalogue and",
    "canonicalised to the catalogue's own spelling."
  ],
  "defaults": {
    "themeMode": "SYSTEM",
    "dayChangeHour": 4,
    "dayChangeMinute": 0,
    "dailyLimitGrams": 20.0,
    "weeklyLimitGrams": 100.0,
    "maxDrinkDaysPerWeek": 5,
    "statsFromDate": "",
    "biometricEnabled": false,
    "allowScreenshots": false,
    "language": "",
    "weightKg": 0.0,
    "alternativeStatusSymbols": false
  },
  "localeTags": [
    "da",
    "de",
    "en",
    "es",
    "fr",
    "it",
    "nl",
    "nb",
    "pl",
    "pt",
    "pt-BR",
    "ro",
    "sv",
    "cs",
    "el",
    "ru",
    "uk",
    "zh-CN",
    "zh-TW",
    "ja",
    "ko"
  ],
