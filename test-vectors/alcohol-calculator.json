  "isOverLimit": [
    {
      "description": "Below the limit",
      "totalGrams": 19.9,
      "limitGrams": 20.0,
      "expected": false
    },
    {
      "description": "Exactly at the limit is allowed, not over",
      "totalGrams": 20.0,
      "limitGrams": 20.0,
      "expected": false
    },
    {
      "description": "The smallest real exceedance (0.1 g) is detected",
      "totalGrams": 20.1,
      "limitGrams": 20.0,
      "expected": true
    },
    {
      "description": "Float drift just above the limit is tolerated",
      "totalGrams": 190.60000000000002,
      "limitGrams": 190.6,
      "expected": false
    },
    {
      "description": "Drift-sized excess below epsilon is tolerated",
      "totalGrams": 20.0000005,
      "limitGrams": 20.0,
      "expected": false
    },
    {
      "description": "Excess above epsilon is a real exceedance",
      "totalGrams": 20.00001,
      "limitGrams": 20.0,
      "expected": true
