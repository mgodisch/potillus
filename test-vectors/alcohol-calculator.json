{
  "_comment": [
    "Shared golden vectors for AlcoholCalculator. Loaded by BOTH the Android (JVM)",
    "and iOS (Swift) test suites so the two implementations cannot silently diverge.",
    "Harvested from the authoritative Android unit tests. Changing a value here is a",
    "deliberate, reviewable change to health-relevant behaviour.",
    "Tolerances: grams and bac compare with an absolute epsilon of 0.001.",
    "isOverLimit(total, limit) = total > limit + 1e-6. The tolerance exists because 0.1-g values summed as binary doubles can drift above an exactly-met limit; a strict '>' would then report an exceedance the user cannot see."
  ],
  "constants": {
    "ethanolDensity": 0.789,
    "bingeThreshold": 60.0,
    "widmarkR": 0.6,
    "beta": 0.15,
    "windowDays": 7,
    "limitEpsilon": 1e-06
  },
  "calculateGrams": [
    {
      "description": "Pils, 500 ml at 4.9%",
      "volumeMl": 500,
      "alcoholPercent": 4.9,
      "expected": 19.3
    },
    {
      "description": "Red wine, 200 ml at 13%",
      "volumeMl": 200,
      "alcoholPercent": 13.0,
      "expected": 20.5
    },
    {
      "description": "Whisky, 40 ml at 40%",
      "volumeMl": 40,
      "alcoholPercent": 40.0,
      "expected": 12.6
    },
    {
      "description": "Alcohol-free drink yields zero",
      "volumeMl": 500,
      "alcoholPercent": 0.0,
      "expected": 0.0
    },
    {
      "description": "Rounds to one decimal",
      "volumeMl": 330,
      "alcoholPercent": 4.9,
      "expected": 12.8
    },
    {
      "description": "188 ml at 13.5% is exactly 20.0 g, not over a 20 g limit",
      "volumeMl": 188,
      "alcoholPercent": 13.5,
      "expected": 20.0
    }
  ],
  "calculateBAC": [
    {
      "description": "80 kg, 20 g, 0 h",
