      "expected": 0.89
    },
    {
      "description": "75 kg, 40 g, 2 h \u2014 decays by beta per hour",
      "totalGrams": 40.0,
      "weightKg": 75.0,
      "hoursElapsed": 2.0,
      "expected": 0.59
    },
    {
      "description": "Never negative: fully eliminated after 10 h",
      "totalGrams": 10.0,
      "weightKg": 80.0,
      "hoursElapsed": 10.0,
      "expected": 0.0
    },
    {
      "description": "Zero weight returns zero",
      "totalGrams": 20.0,
      "weightKg": 0.0,
      "hoursElapsed": 0.0,
      "expected": 0.0
    },
    {
      "description": "Zero grams returns zero",
      "totalGrams": 0.0,
      "weightKg": 80.0,
      "hoursElapsed": 0.0,
      "expected": 0.0
    },
    {
      "description": "Negative elapsed hours are coerced to zero",
      "totalGrams": 20.0,
      "weightKg": 80.0,
      "hoursElapsed": -5.0,
      "expected": 0.42
    }
  ],
  "limitPercent": [
    {
      "description": "Half of the daily limit",
      "totalGrams": 10.0,
      "limitGrams": 20.0,
      "expected": 0.5
