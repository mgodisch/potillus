# Fastfile -- fastlane lanes for Libellus Potionis
# =============================================================================
#
# Currently this defines a single lane, `screenshots`, that captures the six
# in-app Play-Store screenshots through Fastlane screengrab (configuration in
# Screengrabfile). It is intended to be invoked by the `make screenshots-android` target
# (android/Makefile), which wraps it with Android Demo Mode set-up/tear-down,
# device-date pinning and PDF-report rendering (screenshots 07/08).
#
# Running the lane on its own is possible (`bundle exec fastlane screenshots`),
# but then the status bar is NOT cleaned and the PDF pages are NOT produced â€”
# use `make screenshots-android` for the complete, Play-ready asset set.
# =============================================================================

default_platform(:android)

platform :android do
  desc 'Capture the in-app Play-Store screenshots (all store locales) via screengrab.'
  desc 'Prefer `make screenshots-android`, which also cleans the status bar (Demo Mode)'
  desc 'and renders the PDF report pages as screenshots 07/08.'
  lane :screenshots do
    # `capture_android_screenshots` is the modern alias of the `screengrab`
    # action. It reads Screengrabfile, installs the APKs, and for each locale
    # runs the screenshot suite and pulls the PNGs into the fastlane metadata
    # tree. Demo Mode and PDF rendering are handled by the Makefile around this.
    capture_android_screenshots
  end

  # â”€â”€ upload_release â”€â”€ the single upload_to_play_store call shared by the public
  # `testing` and `production` lanes below. Only the track and release status differ
  # between them, so the rest lives here ONCE (the same drift-avoidance principle
  # the rest of the tooling follows). Private: not listed by `fastlane lanes` and
  # not callable from the CLI -- go through `testing` / `production`.
  #
  # `upload_to_play_store` is the modern alias of the `supply` action. It reads the
  # package_name and the service-account key from the Appfile, uploads the AAB
  # produced by `./gradlew bundleRelease`, and syncs the listing texts, changelogs
  # and images from fastlane/metadata/android/ -- the SAME tree F-Droid reads, so
  # the two stores never diverge.
  private_lane :upload_release do |options|
    upload_to_play_store(
      # AAB (not APK): Google Play requires the App Bundle format for new apps.
      aab: 'android/app/build/outputs/bundle/release/app-release.aab',

      # Track and release status are chosen by the calling lane.
      track: options[:track],
      release_status: options[:status],

      # We upload a bundle, never a bare APK, so disable the APK upload paths.
      skip_upload_apk: true,

      # OVERWRITE the store listing from fastlane/metadata/android/: every skip_*
      # is false, so the titles, descriptions, feature graphics, screenshots and
      # changelogs are all (re)uploaded, replacing what is live -- making the repo
      # the single source of truth for the listing on every track.
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      skip_upload_images: false,
      skip_upload_screenshots: false
    )
  end

  desc 'Upload the SIGNED release App Bundle to the closed-testing ALPHA track'
  desc 'and OVERWRITE the store listing + release notes on Google Play (titles,'
  desc 'short/full descriptions, feature graphics, screenshots and changelogs'
  desc 'from fastlane/metadata/android/). Build the bundle first with'
  desc '`make -C android bundle` (or `make release`); the Makefile `push-playstore`'
  desc 'target guards that prerequisite -- this lane does NOT build it.'
  desc 'Options (all optional):'
  desc '  track:<name>   Play track (default: alpha). For production use the'
  desc '                 dedicated `production` lane below.'
  desc '  status:<name>  release status draft|completed|halted|inProgress'
  desc '                 (default: completed -- testing tracks expect completed).'
  desc 'Example:  bundle exec fastlane testing track:beta status:draft'
  lane :testing do |options|
    upload_release(
      track: options[:track] || 'alpha',
      status: options[:status] || 'completed',
    )
  end

  desc 'Upload the SIGNED release App Bundle to the PRODUCTION track and OVERWRITE'
  desc 'the store listing + release notes on Google Play. Same build prerequisite'
  desc 'as `testing` (this lane does NOT build the AAB). Staged as a DRAFT by'
  desc 'default: the release waits in the Play Console for you to review and'
  desc 'publish manually, rather than going live automatically. NOTE: a new'
  desc 'personal developer account cannot publish to production until the'
  desc 'closed-testing gate is cleared (12 testers / 14 days -- docs/PLAY_STORE.md Â§5).'
  desc 'Options (all optional):'
  desc '  track:<name>   Play track (default: production).'
  desc '  status:<name>  release status draft|completed|halted|inProgress'
  desc '                 (default: draft -- stage for manual review/publish).'
  desc 'Example:  bundle exec fastlane production status:completed'
  lane :production do |options|
    upload_release(
      track: options[:track] || 'production',
      status: options[:status] || 'draft',
    )
  end
end

# =============================================================================
# iOS platform -- App Store Connect lanes (mirror of the Android block above)
# =============================================================================
#
# These lanes manage the App Store listing the same way the Android lanes manage
# the Play listing: the repository is the single source of truth. The listing
# texts, keywords and release notes live in fastlane/metadata/ios/ and are pushed
# verbatim on every upload, so the App Store and the Play Store never drift from
# what is committed here.
#
# AUTHENTICATION -- App Store Connect API key (.p8), the modern, 2FA-proof method.
#   `app_store_connect_api_key` reads three values and stores the resulting token
#   in fastlane's lane context, from where `deliver`/`snapshot` pick it up
#   automatically. All three are SECRETS injected via the environment (never
#   committed); fastlane's own default env names are used, so no wiring is needed:
#     APP_STORE_CONNECT_API_KEY_KEY_ID       -- the key's ID (e.g. D383SF739)
#     APP_STORE_CONNECT_API_KEY_ISSUER_ID    -- the team's issuer ID (a UUID)
#     APP_STORE_CONNECT_API_KEY_KEY_FILEPATH -- path to the downloaded AuthKey_*.p8
#   Create the key in App Store Connect â†’ Users and Access â†’ Integrations â†’ Keys.
#   The .p8 is git-ignored (.gitignore â†’ /fastlane/AuthKey_*.p8); it downloads
#   ONCE and cannot be re-downloaded, so store it safely.
#
# BUILDING -- like the Android lanes, these lanes do NOT build the app. Produce a
#   signed .ipa on the Mac first (Xcode or `make -C ios archive`, see ios/), then
#   run the upload lane. Screenshots are produced by the `screenshots` lane below.

platform :ios do
  desc 'Capture the App Store screenshots (all store locales) via snapshot.'
  desc 'Requires a UI-test scheme that drives the app through the six screens;'
  desc 'configuration lives in Snapfile. Prefer `make screenshots-ios`, which'
  desc 'pins the device date and renders the two PDF-report pages, mirroring the'
  desc 'Android `make screenshots-android` flow.'
  lane :screenshots do
    # `capture_ios_screenshots` is the modern alias of the `snapshot` action. It
    # reads Snapfile, builds the UI-test target, and runs it across every
    # simulator/locale pair, collecting the PNGs into the fastlane screenshots
    # tree. Status-bar cleanup and PDF rendering are handled around this by the
    # Makefile, exactly as on Android.
    capture_ios_screenshots
  end

  # â”€â”€ upload_appstore â”€â”€ the single upload_to_app_store call shared by the public
  # `testing` and `production` lanes below. Only submit_for_review and the review
  # submission differ between them; the rest lives here ONCE (same drift-avoidance
  # principle as the Android upload_release). Private: go through `testing` /
  # `production`.
  #
  # `upload_to_app_store` is the modern alias of the `deliver` action. It reads the
  # app_identifier from the Appfile, uploads the signed .ipa, and syncs the listing
  # texts, keywords and release notes from fastlane/metadata/ios/ -- the single
  # source of truth for the App Store listing.
  private_lane :upload_appstore do |options|
    # Authenticate first; the token lands in lane_context for deliver to use.
    app_store_connect_api_key

    upload_to_app_store(
      # The signed app binary. Build it on the Mac before running this lane.
      ipa: 'ios/build/Potillus.ipa',

      # Metadata + screenshots come from fastlane/metadata/ios/ (the default path
      # once platform is ios). Push them on every upload so the listing matches
      # the repository -- every skip_* below is false.
      skip_metadata: false,
      skip_screenshots: false,

      # precheck scans the listing for common rejection reasons before upload.
      run_precheck_before_submit: true,

      # Whether to actually submit the uploaded build for Apple review is chosen
      # by the calling lane; `production` submits, `testing` only uploads.
      submit_for_review: options[:submit],

      # Never overwrite the (manually curated) age rating or pricing.
      force: true, # skip the HTML-report confirmation prompt (non-interactive)
      precheck_include_in_app_purchases: false
    )
  end

  desc 'Upload the SIGNED .ipa and OVERWRITE the App Store listing + release notes'
  desc '(names, subtitles, keywords, descriptions and screenshots from'
  desc 'fastlane/metadata/ios/) WITHOUT submitting for review. The build lands in'
  desc 'App Store Connect as "Prepare for Submission" / TestFlight for you to check.'
  desc 'Build the .ipa first (Xcode or `make -C ios archive`); this lane does NOT'
  desc 'build it.'
  lane :testing do
    upload_appstore(submit: false)
  end

  desc 'Upload the SIGNED .ipa, OVERWRITE the App Store listing, and SUBMIT the'
  desc 'build for Apple review. Same build prerequisite as `testing` (this lane'
  desc 'does NOT build the .ipa). Apple review gates the actual release; nothing'
  desc 'goes live automatically without passing review.'
  lane :production do
    upload_appstore(submit: true)
  end
end
