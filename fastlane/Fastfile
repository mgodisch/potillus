# Fastfile -- fastlane lanes for Libellus Potionis
# =============================================================================
#
# Currently this defines a single lane, `screenshots`, that captures the six
# in-app Play-Store screenshots through Fastlane screengrab (configuration in
# Screengrabfile). It is intended to be invoked by the `make screenshots` target
# (android/Makefile), which wraps it with Android Demo Mode set-up/tear-down,
# device-date pinning and PDF-report rendering (screenshots 07/08).
#
# Running the lane on its own is possible (`bundle exec fastlane screenshots`),
# but then the status bar is NOT cleaned and the PDF pages are NOT produced —
# use `make screenshots` for the complete, Play-ready asset set.
# =============================================================================

default_platform(:android)

platform :android do
  desc 'Capture the in-app Play-Store screenshots (all store locales) via screengrab.'
  desc 'Prefer `make screenshots`, which also cleans the status bar (Demo Mode)'
  desc 'and renders the PDF report pages as screenshots 07/08.'
  lane :screenshots do
    # `capture_android_screenshots` is the modern alias of the `screengrab`
    # action. It reads Screengrabfile, installs the APKs, and for each locale
    # runs the screenshot suite and pulls the PNGs into the fastlane metadata
    # tree. Demo Mode and PDF rendering are handled by the Makefile around this.
    capture_android_screenshots
  end

  desc 'Upload the SIGNED release App Bundle and the store metadata to Google Play.'
  desc 'Build the bundle first with `make bundle` (needs a configured signing key,'
  desc 'see android/keystore.properties.example). Options (all optional):'
  desc '  track:<name>   Play track to publish to (default: internal). Publishing to'
  desc '                 production requires passing track:production explicitly.'
  desc '  status:<name>  release status: draft|completed|halted|inProgress (default: draft)'
  desc 'Example:  bundle exec fastlane deploy track:internal status:completed'
  lane :deploy do |options|
    # `upload_to_play_store` is the modern alias of the `supply` action. It reads
    # the package_name and the service-account key from the Appfile, uploads the
    # AAB produced by `./gradlew bundleRelease`, and syncs the listing texts,
    # changelogs and images from fastlane/metadata/android/ — the SAME tree that
    # F-Droid reads, so the two stores never diverge.
    upload_to_play_store(
      # AAB (not APK): Google Play requires the App Bundle format for new apps.
      aab: 'android/app/build/outputs/bundle/release/app-release.aab',

      # Default to the INTERNAL testing track: it is the safe, low-blast-radius
      # target, and a new personal developer account cannot publish to production
      # at all until the closed-testing gate is cleared (12 testers / 14 days —
      # see docs/PLAY_STORE.md §5). Reaching production is therefore a deliberate,
      # explicit act: pass `track:production`. Staged rollouts use the same
      # override (e.g. `track:closed`).
      #
      # `release_status: draft` keeps a production upload staged in the Play
      # Console for manual review/publish instead of going live automatically.
      # NOTE: the testing tracks (internal/closed) expect a COMPLETED release, so
      # pair them with `status:completed` (as the Example line above shows); the
      # draft default is meaningful for the production track.
      track: options[:track] || 'internal',
      release_status: options[:status] || 'draft',

      # We upload a bundle, never a bare APK, so disable the APK upload paths.
      skip_upload_apk: true,

      # Sync the store listing from fastlane/metadata/android/. The full image set
      # (icon, feature graphic and phone screenshots) is present, so images are
      # pushed too. If you ever want to update only texts/changelogs, set
      # skip_upload_images and skip_upload_screenshots to true.
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      skip_upload_images: false,
      skip_upload_screenshots: false
    )
  end
end
