# =============================================================================
# Fastfile -- fastlane lanes for Libellus Potionis
# =============================================================================
#
# This defines the lanes for BOTH platforms, in two blocks that mirror each
# other. Android (`platform :android`, the default): `screenshots` captures the
# in-app Play-Store screenshots via screengrab (configuration in Screengrabfile),
# and `testing` / `production` upload an already-built, signed App Bundle plus the
# store listing to Google Play. iOS (`platform :ios`): `screenshots` captures the
# App Store screenshots via snapshot (Snapfile), `alpha` uploads an already-built,
# signed .ipa to internal TestFlight, `testing` / `production` upload it plus the
# App Store listing, and `preflight` checks the App Store Connect credentials
# without uploading anything. NO lane builds anything -- see the per-lane `desc`
# text and the platform-level comment before the iOS block for the details.
#
# The screenshot lanes are intended to be invoked by the `make screenshots-android`
# and `make screenshots-ios` targets (the top-level Makefile), which wrap them with
# Demo Mode / status-bar set-up and tear-down, device-date pinning and PDF-report
# rendering (screenshots 07/08).
#
# Running a screenshot lane on its own is possible (`bundle exec fastlane
# screenshots`), but then the status bar is NOT cleaned and the PDF pages are NOT
# produced -- use the `make` targets for the complete, store-ready asset set.
# =============================================================================

default_platform(:android)

platform :android do
  desc 'Capture the in-app Play-Store screenshots (all store locales) via screengrab.'
  desc 'Prefer `make screenshots-android`, which also cleans the status bar (Demo Mode)'
  desc 'and renders the PDF report pages as screenshots 07/08.'
  lane :screenshots do
    # `capture_android_screenshots` is the modern alias of the `screengrab`
    # action. It reads Screengrabfile, installs the APKs, and for each locale
    # runs the screenshot suite and pulls the PNGs into the fastlane metadata
    # tree. Demo Mode and PDF rendering are handled by the Makefile around this.
    capture_android_screenshots
  end

  # ── upload_release ── the single upload_to_play_store call shared by the public
  # `testing` and `production` lanes below. Only the track and release status differ
  # between them, so the rest lives here ONCE (the same drift-avoidance principle
  # the rest of the tooling follows). Private: not listed by `fastlane lanes` and
  # not callable from the CLI -- go through `testing` / `production`.
  #
  # `upload_to_play_store` is the modern alias of the `supply` action. It reads the
  # package_name and the service-account key from the Appfile, uploads the AAB
  # produced by `./gradlew bundleRelease`, and syncs the listing texts, changelogs
  # and images from fastlane/metadata/android/ -- the SAME tree F-Droid reads, so
  # the two stores never diverge.
  private_lane :upload_release do |options|
    upload_to_play_store(
      # AAB (not APK): Google Play requires the App Bundle format for new apps.
      # The path is supplied by the caller so `make push-playstore` can upload the
      # STAGED bundle (releases/<applicationId>_<versionCode>.aab) it has verified,
      # rather than the raw Gradle output. Falls back to the Gradle path when the
      # lane is run directly without an aab: option.
      aab: options[:aab] || 'android/app/build/outputs/bundle/release/app-release.aab',

      # Track and release status are chosen by the calling lane.
      track: options[:track],
      release_status: options[:status],

      # Dry-run switch. When true, supply VALIDATES the edit against the Play API
      # but changes nothing on Google Play (default false). Passed through from the
      # testing / production lanes; coerced with to_s so it behaves whether the
      # lane option arrives as a boolean or as a string CLI argument.
      validate_only: options[:validate_only].to_s == 'true',

      # We upload a bundle, never a bare APK, so disable the APK upload paths.
      skip_upload_apk: true,

      # OVERWRITE the store listing from fastlane/metadata/android/: every skip_*
      # is false, so the titles, descriptions, feature graphics, screenshots and
      # changelogs are all (re)uploaded, replacing what is live -- making the repo
      # the single source of truth for the listing on every track.
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      skip_upload_images: false,
      skip_upload_screenshots: false
    )
  end

  desc 'Upload the SIGNED release App Bundle to the closed-testing ALPHA track'
  desc 'and OVERWRITE the store listing + release notes on Google Play (titles,'
  desc 'short/full descriptions, feature graphics, screenshots and changelogs'
  desc 'from fastlane/metadata/android/). Build the bundle first with'
  desc '`make -C android bundle` (or `make release`); the Makefile `push-playstore`'
  desc 'target guards that prerequisite -- this lane does NOT build it.'
  desc 'Options (all optional):'
  desc '  track:<name>   Play track (default: alpha). For production use the'
  desc '                 dedicated `production` lane below.'
  desc '  status:<name>  release status draft|completed|halted|inProgress'
  desc '                 (default: completed -- testing tracks expect completed).'
  desc '  validate_only:<bool>  Dry run -- validate the upload against the Play API'
  desc '                 without changing anything on Google Play (default false).'
  desc 'Example:  bundle exec fastlane testing track:beta status:draft'
  lane :testing do |options|
    upload_release(
      track: options[:track] || 'alpha',
      status: options[:status] || 'completed',
      validate_only: options[:validate_only],
      aab: options[:aab],
    )
  end

  desc 'Upload the SIGNED release App Bundle to the PRODUCTION track and OVERWRITE'
  desc 'the store listing + release notes on Google Play. Same build prerequisite'
  desc 'as `testing` (this lane does NOT build the AAB). Staged as a DRAFT by'
  desc 'default: the release waits in the Play Console for you to review and'
  desc 'publish manually, rather than going live automatically. NOTE: a new'
  desc 'personal developer account cannot publish to production until the'
  desc 'closed-testing gate is cleared (12 testers / 14 days).'
  desc 'Options (all optional):'
  desc '  track:<name>   Play track (default: production).'
  desc '  status:<name>  release status draft|completed|halted|inProgress'
  desc '                 (default: draft -- stage for manual review/publish).'
  desc '  validate_only:<bool>  Dry run -- validate the upload against the Play API'
  desc '                 without changing anything on Google Play (default false).'
  desc 'Example:  bundle exec fastlane production status:completed'
  lane :production do |options|
    upload_release(
      track: options[:track] || 'production',
      status: options[:status] || 'draft',
      validate_only: options[:validate_only],
      aab: options[:aab],
    )
  end
end

# =============================================================================
# iOS platform -- App Store Connect lanes (mirror of the Android block above)
# =============================================================================
#
# These lanes manage the App Store listing the same way the Android lanes manage
# the Play listing: the repository is the single source of truth. The listing
# texts, keywords and release notes live in fastlane/metadata/ios/ and are pushed
# verbatim on every upload, so the App Store and the Play Store never drift from
# what is committed here.
#
# AUTHENTICATION -- App Store Connect API key (.p8), the modern, 2FA-proof method.
#   `app_store_connect_api_key` reads three values and stores the resulting token
#   in fastlane's lane context, from where `deliver`/`snapshot` pick it up
#   automatically. All three are SECRETS injected via the environment (never
#   committed); fastlane's own default env names are used, so no wiring is needed:
#     APP_STORE_CONNECT_API_KEY_KEY_ID       -- the key's ID (e.g. D383SF739)
#     APP_STORE_CONNECT_API_KEY_ISSUER_ID    -- the team's issuer ID (a UUID)
#     APP_STORE_CONNECT_API_KEY_KEY_FILEPATH -- path to the downloaded AuthKey_*.p8
#   Create the key in App Store Connect → Users and Access → Integrations → Keys.
#   The .p8 is git-ignored (.gitignore → /fastlane/AuthKey_*.p8); it downloads
#   ONCE and cannot be re-downloaded, so store it safely.
#
# BUILDING -- like the Android lanes, these lanes do NOT build the app. Produce a
#   signed .ipa on the Mac first with `make release-ios` (which archives, exports
#   and stages it into releases/; Xcode's Archive → Distribute flow works too),
#   then run an upload lane. Every upload lane takes the staged .ipa as `ipa:`
#   (mirroring how the Android lanes take `aab:`), defaulting to the raw build
#   output ios/build/Potillus.ipa when none is passed. Screenshots are produced by
#   the `screenshots` lane below.

platform :ios do
  desc 'Capture the App Store screenshots (all store locales) via snapshot.'
  desc 'Requires a UI-test scheme that drives the app through the six screens;'
  desc 'configuration lives in Snapfile. Prefer `make screenshots-ios`, which'
  desc 'pins the device date and renders the two PDF-report pages, mirroring the'
  desc 'Android `make screenshots-android` flow.'
  lane :screenshots do
    # `capture_ios_screenshots` is the modern alias of the `snapshot` action. It
    # reads Snapfile, builds the UI-test target, and runs it across every
    # simulator/locale pair, collecting the PNGs into the fastlane screenshots
    # tree. Status-bar cleanup and PDF rendering are handled around this by the
    # Makefile, exactly as on Android.
    capture_ios_screenshots
  end

  # ── preflight ── prove, BEFORE anything is uploaded, that the App Store Connect
  # API key in the environment actually authenticates AND that this app's record is
  # reachable with it. The Android counterpart of this guard lives in the Makefile
  # (`push-playstore` runs `fastlane run validate_play_store_json_key`), because
  # supply's key is a plain file path and fastlane's CLI takes it as a string. The
  # iOS credential cannot travel that way: `app_store_connect_api_key` returns a
  # HASH, and fastlane's `run` CLI supports only primitive types -- "Hashes are not
  # currently supported" (docs.fastlane.tools). So the check lives HERE, in Ruby,
  # where the hash is passed directly, and `make push-appstore` calls this lane.
  #
  # `app_store_build_number` is a read-only App Store Connect query, which makes it
  # a cheap, side-effect-free way to exercise the whole path: the key file, the key
  # ID and issuer ID, the key's role, and the existence of the app record for the
  # Appfile's app_identifier. Two options keep it from failing on a healthy app:
  #   live: false            -- query the edit/TestFlight train, not the ready-for-
  #                             sale one, which does not exist until a first release
  #                             has actually gone live.
  #   initial_build_number:0 -- documented as "sets the build number to given value
  #                             if no build (upload) is in current train", i.e. a
  #                             brand-new app with no build yet answers 0 instead of
  #                             erroring. We do not use the number; reaching it IS
  #                             the check.
  desc 'Verify the App Store Connect API key authenticates and this app is reachable.'
  desc 'Read-only: queries the current build number and uploads nothing. Run by'
  desc '`make push-appstore` before the upload; useful on its own to test credentials.'
  lane :preflight do
    api_key = app_store_connect_api_key

    build_number = app_store_build_number(
      api_key: api_key,
      live: false,
      initial_build_number: 0
    )

    UI.success("preflight: App Store Connect reachable; current build number: #{build_number}")
  end

  desc 'Upload the SIGNED .ipa to TestFlight for INTERNAL testing. Unlike the'
  desc 'App Store lanes below, this pushes NO listing metadata or screenshots --'
  desc 'internal TestFlight does not use them. Build the .ipa first with'
  desc '`make release-ios`, then pass the staged path, e.g.'
  desc '`bundle exec fastlane ios alpha ipa:releases/de.godisch.potillus_<code>.ipa`.'
  lane :alpha do |options|
    # Authenticate with the App Store Connect API key. Capturing the return value
    # and passing it explicitly to upload_to_testflight is the documented pattern
    # for that action (the App Store lanes below instead rely on the token that
    # the same call leaves in lane_context for deliver).
    api_key = app_store_connect_api_key

    upload_to_testflight(
      api_key: api_key,

      # The signed binary. Defaults to the raw build output, but normally the
      # caller passes the staged releases/ path that `make release-ios` prints --
      # the same `ipa:`/`aab:` option convention the Android lanes use.
      ipa: options[:ipa] || 'ios/build/Potillus.ipa',

      # Internal testing only: no Beta App Review, no external groups. External
      # distribution (public groups) would additionally need a review and beta
      # metadata and is intentionally not wired here (see docs/RELEASE-IOS.md).
      distribute_external: false,

      # Do not block the lane waiting for App Store Connect to finish processing
      # the build: the upload is what matters here, and internal testers are
      # notified per the App Store Connect settings once processing completes.
      skip_waiting_for_build_processing: true
    )
  end

  # ── upload_appstore ── the single upload_to_app_store call shared by the public
  # `testing` and `production` lanes below. Only submit_for_review and the review
  # submission differ between them; the rest lives here ONCE (same drift-avoidance
  # principle as the Android upload_release). Private: go through `testing` /
  # `production`.
  #
  # `upload_to_app_store` is the modern alias of the `deliver` action. It reads the
  # app_identifier from the Appfile, uploads the signed .ipa, and syncs the listing
  # texts, keywords and release notes from fastlane/metadata/ios/ -- the single
  # source of truth for the App Store listing.
  private_lane :upload_appstore do |options|
    # Authenticate first; the token lands in lane_context for deliver to use.
    app_store_connect_api_key

    upload_to_app_store(
      # The signed app binary. Defaults to the raw build output, but the caller
      # normally passes the staged releases/ path from `make release-ios` as
      # `ipa:` -- mirroring how the Android lanes take `aab:`.
      ipa: options[:ipa] || 'ios/build/Potillus.ipa',

      # Metadata + screenshots come from fastlane/metadata/ios/ (the default path
      # once platform is ios). Push them on every upload so the listing matches
      # the repository -- every skip_* below is false.
      skip_metadata: false,
      skip_screenshots: false,

      # precheck scans the listing for common rejection reasons before upload.
      run_precheck_before_submit: true,

      # Whether to actually submit the uploaded build for Apple review is chosen
      # by the calling lane; `production` submits, `testing` only uploads.
      submit_for_review: options[:submit],

      # Skip deliver's interactive confirmation of the generated HTML preview
      # report, so the lane runs unattended. It does NOT force anything onto the
      # listing beyond what the skip_* switches above already push.
      force: true,

      # precheck's in-app-purchase scan needs App Store Connect permissions this
      # app has no use for: it ships no in-app purchases. Turning the scan off
      # keeps precheck from failing on a category that cannot apply here.
      precheck_include_in_app_purchases: false
    )
  end

  desc 'Upload the SIGNED .ipa and OVERWRITE the App Store listing + release notes'
  desc '(names, subtitles, keywords, descriptions and screenshots from'
  desc 'fastlane/metadata/ios/) WITHOUT submitting for review. The build lands in'
  desc 'App Store Connect as "Prepare for Submission" / TestFlight for you to check.'
  desc 'Build the .ipa first with `make release-ios`; this lane does NOT build it.'
  desc 'Pass the staged path as ipa:, e.g. ipa:releases/de.godisch.potillus_<code>.ipa.'
  lane :testing do |options|
    upload_appstore(submit: false, ipa: options[:ipa])
  end

  desc 'Upload the SIGNED .ipa, OVERWRITE the App Store listing, and SUBMIT the'
  desc 'build for Apple review. Same build prerequisite as `testing` (this lane'
  desc 'does NOT build the .ipa). Apple review gates the actual release; nothing'
  desc 'goes live automatically without passing review.'
  lane :production do |options|
    upload_appstore(submit: true, ipa: options[:ipa])
  end
end
