# Screengrabfile -- configuration for `fastlane screengrab`
# =============================================================================
#
# This file is consumed by the `capture_android_screenshots` (alias `screengrab`)
# action invoked from the `screenshots` lane in Fastfile. It is itself driven by
# the `make screenshots` target (android/Makefile), which sets up Android Demo
# Mode and the device date BEFORE calling fastlane and tears Demo Mode down
# afterwards, then renders the two PDF report pages as screenshots 07/08.
#
# All relative paths below are resolved from the directory fastlane re-anchors to,
# which â€” now that this fastlane/ tree lives at the repository root â€” is the REPO
# root (a sibling of android/), see the Makefile recipe: `cd ../fastlane &&
# bundle exec fastlane screenshots`. Paths into the Gradle build outputs therefore
# carry the `android/` prefix, while the metadata output stays under `fastlane/`.
# =============================================================================

# Application id of the build under test. The debug build appends ".debug"
# (see app/build.gradle.kts buildTypes.debug.applicationIdSuffix), so the
# instrumentation target and test package are suffixed accordingly.
app_package_name('de.godisch.potillus.debug')
tests_package_name('de.godisch.potillus.debug.test')

# Pre-built APKs (the Makefile runs `assembleDebug assembleDebugAndroidTest`
# first). Providing them lets screengrab (re)install before capturing.
app_apk_path('android/app/build/outputs/apk/debug/app-debug.apk')
tests_apk_path('android/app/build/outputs/apk/androidTest/debug/app-debug-androidTest.apk')

# Capture only the dedicated screenshot suite, not the whole instrumented test
# set. This is also why the @ScreenshotOnly opt-out (used by `make test-device
# EXCLUDE_SCREENSHOTS=1`) never interferes with capturing.
use_tests_in_packages(['de.godisch.potillus.screenshot'])

# AndroidX test runner (matches testInstrumentationRunner in build.gradle.kts).
test_instrumentation_runner('androidx.test.runner.AndroidJUnitRunner')

# The store locales to capture, discovered from the metadata tree instead of
# being hard-coded: every fastlane/metadata/android/<locale>/ directory carries a
# changelogs/ sub-dir, so this yields exactly the locale set (and skips the
# non-locale screenshots.html). It is the SAME derivation the Makefile's
# SCREENSHOT_LOCALES uses, so capture, cropping, validation and the feature
# graphic all cover an identical set that grows automatically when a locale dir
# is added. Paths are resolved from the repo root (see the header note).
# en-US is captured first so the base locale is grabbed before the rest.
# screengrab runs the suite once per locale and passes the value to the test as
# the `testlocale` argument (read by ScreenshotTest and LocaleTestRule).
locales(
  Dir.glob('fastlane/metadata/android/*/changelogs')
     .map { |p| File.basename(File.dirname(p)) }
     .sort_by { |l| [l == 'en-US' ? 0 : 1, l] }
)

# Wipe the previous PNGs so a re-run cannot leave stale shots behind. The PDF
# pages (07/08) are added by the Makefile AFTER screengrab finishes, so this
# clear never removes them.
clear_previous_screenshots(true)

# Output root. screengrab writes <output_directory>/<locale>/images/
# phoneScreenshots/, i.e. straight into the existing fastlane metadata tree that
# both Google Play (`fastlane supply`) and F-Droid already read.
output_directory('fastlane/metadata/android')

# Reinstall the app between locales so each run starts from cleared app data;
# ScreenshotTest re-seeds the demo database on every run, so this is safe.
reinstall_app(true)

# Fail the lane (and therefore `make screenshots`) if any instrumentation test
# fails, instead of silently producing an incomplete screenshot set.
exit_on_test_failure(true)

# Stable, timestamp-free filenames. By default screengrab passes
# `-e appendTimestamp true` to the test, so every run writes a NEW file like
# `01_today_<timestamp>.png` and leaves the old ones behind. Disabling it makes
# the capture write exactly `01_today.png` â€¦ `06_settings.png`, which overwrite
# in place on each run â€” so the committed screenshots can be re-generated and
# checked in without producing churn or duplicate files.
use_timestamp_suffix(false)
