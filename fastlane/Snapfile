# Snapfile -- configuration for `fastlane snapshot` (iOS App Store screenshots)
# =============================================================================
#
# This file is consumed by the `capture_ios_screenshots` (alias `snapshot`)
# action invoked from the `screenshots` lane in the Fastfile's `platform :ios`
# block. It is the iOS counterpart to Screengrabfile, and is likewise intended
# to be driven by a Makefile target (`make -C ios screenshots`) that pins the
# simulator date and renders the two PDF-report pages as screenshots 07/08,
# mirroring the Android `make screenshots` flow.
#
# UNLIKE Android, iOS screenshots are produced by a UI-TEST target running in the
# iOS Simulator: snapshot builds the scheme's UI-test bundle, launches the app in
# each simulator/locale combination, drives it through the screens, and calls
# snapshot("01_today") etc. from the test to save each frame. The scheme and the
# UI-test target are NOT part of this change (they belong with the app project in
# ios/); the placeholders below name what that scheme must be called.
#
# All relative paths are resolved from the repository root (the directory fastlane
# re-anchors to), a sibling of ios/ -- hence the `ios/` prefix on the project path.
# =============================================================================

# The Xcode project (generated by XcodeGen from ios/project.yml) and the scheme
# that hosts the UI-test target which drives the screenshots. PLACEHOLDER: the
# `PotillusUITests` scheme and its snapshot helper are added with the app target
# on the Mac; until then this lane cannot run. The names below are the contract.
project("ios/Potillus.xcodeproj")
scheme("PotillusUITests")

# Where snapshot writes the captured PNGs. It creates <output_directory>/<locale>/
# with one file per snapshot() call. Kept OUT of the metadata tree (unlike Android,
# whose screengrab writes straight into metadata/android/): deliver reads iOS
# screenshots from a screenshots path, and the Makefile copies the final,
# status-bar-cleaned set plus the PDF pages into place.
output_directory("fastlane/screenshots/ios")

# Overwrite in place so re-runs don't accumulate stale frames (matches the Android
# `use_timestamp_suffix(false)` intent).
clear_previous_screenshots(true)

# The App Store store locales to capture. Discovered from the iOS metadata tree
# instead of being hard-coded: every fastlane/metadata/ios/<locale>/ directory
# carries a name.txt, so this yields exactly the store-locale set and skips the
# global files (copyright.txt, primary_category.txt, review_information/). This is
# the same derivation principle as Screengrabfile. en-US is captured first so the
# base locale is grabbed before the rest.
languages(
  Dir.glob("fastlane/metadata/ios/*/name.txt")
     .map { |p| File.basename(File.dirname(p)) }
     .sort_by { |l| [l == "en-US" ? 0 : 1, l] }
)

# The simulator device to render on. iPhone-only app; a single 6.7"/6.9" device
# covers the required App Store screenshot dimension. PLACEHOLDER: pin to whatever
# simulator the Mac has installed (e.g. "iPhone 16 Pro Max").
devices(["iPhone 17 Pro"])

# A clean status bar (full battery, strong signal, fixed time) like Android Demo
# Mode. snapshot can override the simulator status bar for this.
override_status_bar(true)

# override_status_bar(true) alone passes an ISO-8601 timestamp to simctl, which the
# simulator renders in the host time zone — so in CET/CEST the clock reads 10:41 or
# 11:41, not Apple's canonical 9:41. Passing a bare "9:41" (no date, no zone) is the
# documented, timezone-immune workaround; the rest just restates snapshot's own
# defaults (full signal and battery, no carrier name).
override_status_bar_arguments("--time 9:41 --dataNetwork wifi --wifiMode active --wifiBars 3 --cellularMode active --operatorName '' --cellularBars 4 --batteryState charged --batteryLevel 100")

# Fail the lane if the UI test fails, instead of producing an incomplete set.
stop_after_first_error(true)

# Concurrent simulators speed capture up; 1 keeps runs deterministic and low-noise
# on a single Mac. Raise if the machine has the cores to spare.
concurrent_simulators(false)
