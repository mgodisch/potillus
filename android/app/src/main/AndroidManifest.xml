<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!--
        PERMISSIONS – minimal profile:
        - No network permission
        - No camera, microphone or location
        - No telephony permissions
    -->

    <!--
        Biometrics: USE_FINGERPRINT has been deprecated since API 28 and is fully
        obsolete at minSdk 30. Only USE_BIOMETRIC is required.
    -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- CSV export to the Downloads folder via MediaStore (no WRITE_EXTERNAL_STORAGE needed from API 29 on) -->

    <!--
        ═══════════════════════════════════════════════════════════════════════
        HOW TO ADD A NEW LANGUAGE — checklist (all three steps are required)
        ═══════════════════════════════════════════════════════════════════════

        Step 1 – String resources
          Create app/src/main/res/values-<bcp47>/strings.xml and translate all
          170 string keys.  Use values-de/strings.xml as the source of truth.
          (The exact count is asserted by LocaleSyncTest; if this comment and the
           test ever disagree, the test wins.)
          BCP-47 resource qualifier examples:
            • values-fr/          → French
            • values-pt/          → Portuguese (European)
            • values-pt-rBR/      → Portuguese (Brazilian)   ← note the "r"
            • values-zh-rCN/      → Chinese Simplified
            • values-sr-rLatn/    → Serbian (Latin script)

        Step 2 – locale_config.xml   ← THIS IS THE STEP MOST OFTEN FORGOTTEN
          Add a <locale android:name="…"/> entry to
          app/src/main/res/xml/locale_config.xml.
          Without this entry the language is INVISIBLE in:
            • Android's per-app language picker
              (Settings → Apps → Potillus → Language, API 33+)
            • the in-app language selector
              (SettingsScreen → AppCompatDelegate)
          The android:name value is a plain BCP-47 tag — no "r" prefix,
          hyphen not underscore:
            • values-pt-rBR/ → android:name="pt-BR"
            • values-zh-rCN/ → android:name="zh-CN"

        Step 3 – RTL languages only (Arabic, Hebrew, Persian, Urdu, …)
          Verify android:supportsRtl="true" is set on <application> below
          (it already is).  No further code changes are needed; Compose and
          the Android framework mirror the layout automatically.
        ═══════════════════════════════════════════════════════════════════════
    -->

    <!--
        API-LEVEL NOTE (minSdk 30): android:dataExtractionRules below is honoured
        only on API 31+. On API 30 the attribute is silently ignored, but this is
        harmless — android:allowBackup="false" disables cloud/device-transfer
        backup outright on EVERY supported version, so no personal health data can
        leave the device regardless of API level.

        LINT SUPPRESSIONS on <application>:
        - tools:targetApi="33" — android:localeConfig is an API-33+ attribute,
          knowingly ignored on API 30–32 (the system language picker simply does
          not appear there). This documents that intent (silences UnusedAttribute).
        - tools:ignore="DataExtractionRules" — lint suggests also adding a legacy
          android:fullBackupContent for API < 31. Because allowBackup="false"
          disables ALL backup on every API, such a file would never be consulted,
          so adding one would be dead configuration.
    -->
    <application
        android:name=".PotillusApp"
        tools:targetApi="33"
        tools:ignore="DataExtractionRules"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Potillus"
        android:localeConfig="@xml/locale_config"> <!-- ← Step 2 above: keep locale_config.xml in sync! -->

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            For the AppCompat localisation system (runtime language switching).
            autoStoreLocales=true: Android persists the choice automatically.
        -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

    </application>
</manifest>
