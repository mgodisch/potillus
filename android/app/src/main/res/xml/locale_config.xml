<?xml version="1.0" encoding="utf-8"?>
<!--
    Every locale listed here appears in Android's per-app language picker
    (Settings → Apps → Potillus → Language, API 33+) and in the in-app language
    selector driven by AppCompatDelegate.setApplicationLocales().

    Rules:
    - One <locale> entry per values-XX/ or values-XX-rYY/ resource directory,
      PLUS "en" for the English base that lives in the unqualified values/.
    - The android:name value must match the BCP-47 tag Android derives from
      the resource qualifier:
        values-pt      → "pt"
        values-pt-rBR  → "pt-BR"   (region separator is "-", not "-r")
        values-zh-rCN  → "zh-CN"
    - Keep this list sorted: base locales alphabetically, region variants
      immediately after their base.

    NOTE
    This list, the values-XX/ resource directories AND the docs/guide
    user-guide templates must all stay in sync. Two build-time guards enforce
    this: LocaleSyncTest (values-XX ⇄ locale_config ⇄ SupportedLocales) and
    render-guide.py (values-XX ⇄ usersguide.<tag>.md.in). Every translated
    language therefore needs exactly one <locale> entry here, one strings.xml
    and one guide template, or a build fails.
-->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Czech -->
    <locale android:name="cs"/>
    <!-- Danish -->
    <locale android:name="da"/>
    <!-- German (primary development language / string source of truth) -->
    <locale android:name="de"/>
    <!-- Greek -->
    <locale android:name="el"/>
    <!-- English (base locale / fallback; strings live in values/, not values-en/) -->
    <locale android:name="en"/>
    <!-- Spanish -->
    <locale android:name="es"/>
    <!-- French -->
    <locale android:name="fr"/>
    <!-- Italian -->
    <locale android:name="it"/>
    <!-- Japanese -->
    <locale android:name="ja"/>
    <!-- Korean -->
    <locale android:name="ko"/>
    <!-- Norwegian Bokmål -->
    <locale android:name="nb"/>
    <!-- Dutch -->
    <locale android:name="nl"/>
    <!-- Polish -->
    <locale android:name="pl"/>
    <!-- Portuguese — European -->
    <locale android:name="pt"/>
    <!-- Portuguese — Brazilian (region variant; Android resolves pt-rBR before pt) -->
    <locale android:name="pt-BR"/>
    <!-- Romanian -->
    <locale android:name="ro"/>
    <!-- Russian -->
    <locale android:name="ru"/>
    <!-- Swedish -->
    <locale android:name="sv"/>
    <!-- Ukrainian — Cyrillic; same font stack as Russian -->
    <locale android:name="uk"/>
    <!-- Chinese — Simplified (Mainland China / Singapore) -->
    <locale android:name="zh-CN"/>
    <!-- Chinese — Traditional (Taiwan / Hong Kong / Macau) -->
    <locale android:name="zh-TW"/>
</locale-config>
