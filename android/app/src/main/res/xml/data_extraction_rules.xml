<data-extraction-rules>
    <!--
        This app is fully offline and deliberately keeps all personal health data
        on the device. android:allowBackup is "false", so these rules are not used
        by the platform today; they are kept as a defensive, self-documenting
        statement of intent in case backup is ever enabled.

        Both transports below EXCLUDE the database and the preferences DataStore,
        so personal data never leaves the device through an automatic mechanism.
        The ONLY supported way to move data to another device is the user-initiated
        JSON backup (Settings -> Backup -> Export / Import); see the user's guide.

        NOTE: DataStore has NO dedicated extraction domain. Its backing file lives at
        getFilesDir()/datastore/<name>.preferences_pb, so it belongs to the "file"
        domain (rooted at getFilesDir()) addressed with the "datastore/" path prefix -
        NOT a (non-existent) "datastore" domain, which Android Lint rejects as a
        FullBackupContent error.
    -->
    <cloud-backup>
        <exclude domain="database" path="potillus.db"/>
        <exclude domain="file"     path="datastore/potillus_settings.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="potillus.db"/>
        <exclude domain="file"     path="datastore/potillus_settings.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>
