# =============================================================================
#  Makefile -- Libellus Potionis, Android platform build
# =============================================================================
#
#  Runs from the android/ directory, where the Gradle wrapper lives. The tooling
#  is being rebuilt one target group at a time; THIS revision defines HOUSEKEEPING
#  only. The previous Makefile is preserved as ../attic/android-Makefile.
#
#  TARGETS IN THIS REVISION
#    help       (default) print this list and do nothing else
#    clean      build OUTPUT (app/build, build): regenerated by the next build
#    distclean  clean + the GENERATED SOURCES a build creates into the tree
# =============================================================================

# GNU Make version guard -- see ../make/guard.mk. Included FIRST because the
# .ONESHELL/.SHELLFLAGS settings below are silently ignored on a Make older than
# 3.82, and this Makefile is also invoked directly (`make -C android ...`).
include ../make/guard.mk

# Strict, single-process recipes -- see the identical block in the root Makefile.
SHELL       := /bin/bash
.SHELLFLAGS := -eu -o pipefail -c
.ONESHELL:
.DEFAULT_GOAL := help

help:
	@echo "Libellus Potionis -- Android build (run from android/)"
	@echo
	@echo "Housekeeping (this revision):"
	@echo "  make clean      remove the Gradle build output (app/build, build)"
	@echo "  make distclean  clean + the sources a build generates into the tree"

# =============================================================================
# HOUSEKEEPING
# =============================================================================

# clean removes the build OUTPUT by DELETING the output directories directly,
# rather than invoking `./gradlew clean`. Every artifact this project produces --
# the debug/release APK, the AAB, the CycloneDX SBOM and every test/lint/coverage
# report -- lives under app/build/, so removing that directory (plus the top-level
# Gradle project build/ dir) clears them all. A filesystem delete needs no JVM, no
# Android SDK and no Gradle configuration, so `make clean` works even in a tree
# that cannot yet build, and it is faster. It also matches how the iOS side has
# always cleaned (a plain rm -rf), so "clean" is the same kind of operation on
# both platforms.
#
# Deliberately NOT removed here: the Gradle/Kotlin tool caches (.gradle/,
# .kotlin/). They are not this project's output -- they are expensive-to-refill
# download and daemon caches shared across builds -- so housekeeping leaves them
# in place. Both are git-ignored and re-created on demand; delete them by hand for
# a true cold start.
clean:
	rm -rf app/build build

# distclean additionally removes the sources a build GENERATES into the tree, so
# the working copy returns to its fresh-clone state. Each output is produced by a
# target added in a later revision (the bundled license copies and the localized
# user guides), and each is git-ignored -- which is why removing it loses nothing.
#
# `rm -f` (not a bare `rm`) is deliberate for the guide glob: raw*/usersguide.md
# matches nothing in a tree that never rendered the guides, and a bare `rm` on the
# then-unexpanded pattern would fail and abort this recipe under `set -e`. -f both
# tolerates the missing files and keeps the recipe from aborting.
distclean: clean
	rm -f app/src/main/res/raw/license_gpl3.md
	rm -f app/src/main/res/raw/license_apache2.md
	rm -f app/src/main/res/raw/license_gpl2.md
	rm -f app/src/main/res/raw*/usersguide.md
	rm -f guides.d

.PHONY: help clean distclean
